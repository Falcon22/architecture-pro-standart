@startuml
!include <C4/C4_Container>

title C4 Containers - Подача заявки на кредит онлайн\nContainer diagram [Банк "Стандарт"]

Person(client, "Клиент", "")
Person(fo_manager, "Менеджер фронт-офиса", "")
Person(bo_manager, "Менеджер бэк-офиса", "")

System_Boundary(site_boundary, "Сайт") {
    Container(site_web, "Credit Page", "PHP / React.js", "Предложения, заявка, мгновенный скоринг") <<new>>
}

System_Boundary(ib_boundary, "Интернет-банк") {
    Container(ib_mono, "Монолит ИБ", "ASP.NET MVC 4.5", "Существующий функционал")
    Container(ib_credit_ui, "Credit UI Module", "ASP.NET MVC", "Предложения, предодобренные, заявка + СМС-подтверждение") <<new>>
    ContainerDb(ib_db, "MS SQL", "MS SQL", "")
}

System_Boundary(credit_boundary, "Credit API Service [НОВАЯ]") {
    Container(credit_api, "Credit API", "Java / Spring Boot", "REST API: предложения, предодобренные, заявки, мгновенный скоринг") <<new>>
    Container(credit_sms, "SMS / OTP Service", "Java / Spring Boot", "Shared с Deposit API") <<new>>
    Container(credit_kafka_prod, "Kafka Producer", "Java", "Публикация заявок в credit-applications") <<new>>
    Container(credit_kafka_cons, "Kafka Consumer", "Java", "Статусы из credit-statuses, условия из credit-conditions") <<new>>
    ContainerDb(credit_db, "Credit DB", "PostgreSQL", "Заявки, предодобренные, кэш условий") <<new>>
    ContainerDb(credit_prescore_db, "Pre-scored offers", "PostgreSQL", "Кэш предодобренных") <<new>>
}

Container(batch, "Pre-scoring Batch Job", "Java / Spring Boot", "Ночной предрасчёт скорингов. Cron: нерабочие часы.") <<new>>

Container(kafka, "Apache Kafka", "Кластер", "credit-applications, credit-statuses, credit-conditions") <<new>>

System_Boundary(pipeline_boundary, "Кредитный конвейер") {
    Container(pipeline_app, "Camunda BPM", "Java / Camunda", "Обработка кредитных заявок, бизнес-процессы")
    Container(pipeline_kafka, "Kafka Adapter", "Java", "Consumer: заявки. Producer: статусы, условия") <<new>>
    ContainerDb(pipeline_db, "Oracle DB", "Oracle", "Конвейер")
}

Container(scoring, "Система скоринга", "Python / Flask / PostgreSQL", "REST API, ML-модель")
System_Ext(bki, "Бюро КИ", "Внешнее REST API")
System_Ext(sms, "СМС-шлюз", "")

System_Boundary(abs_boundary, "АБС") {
    Container(abs_desk, "Десктоп-клиент", "Delphi", "Сквозная заявка")
    Container(abs_kafka_adapter, "Kafka-адаптер АБС", "Java", "Приём кредитных заявок из Kafka -> Oracle") <<new>>
    ContainerDb(abs_db, "Oracle DB", "Oracle", "")
}

Rel(client, site_web, "Заявка, скоринг", "HTTPS")
Rel(client, ib_credit_ui, "Предодобренные, заявка + СМС", "HTTPS")
Rel(site_web, credit_api, "Условия, заявки, скоринг", "REST API")
Rel(ib_credit_ui, credit_api, "Предложения, предодобренные, заявки", "REST API")
Rel(ib_credit_ui, credit_sms, "OTP", "REST")
Rel(credit_api, credit_db, "", "SQL/JDBC")
Rel(credit_api, scoring, "Мгновенный скоринг (заявки с сайта)", "REST API")
Rel(credit_sms, sms, "", "API")
Rel(credit_kafka_prod, kafka, "Заявки", "Produce")
Rel(kafka, credit_kafka_cons, "Статусы, условия", "Consume")
BiRel(kafka, pipeline_kafka, "Прямой канал (минуя АБС!)\nЗаявки <-> Статусы", "Kafka") #Orange
Rel(kafka, abs_kafka_adapter, "Копия заявок для фронт-офиса", "Kafka Consumer")
Rel(abs_kafka_adapter, abs_db, "", "JDBC")
Rel(abs_desk, abs_db, "", "Oracle Client")
Rel(fo_manager, abs_desk, "Сквозная заявка", "Десктоп")
Rel(bo_manager, pipeline_app, "Обработка заявок", "Веб")
Rel(pipeline_app, scoring, "Скоринг", "REST API")
Rel(scoring, bki, "Кредитные истории", "REST")
Rel_L(batch, scoring, "Ночной предрасчёт", "REST API, batch")
Rel_R(batch, credit_prescore_db, "Сохранение предодобренных", "JDBC")
Rel(pipeline_app, pipeline_db, "", "SQL")
BiRel(pipeline_kafka, pipeline_app, "", "Internal")

Rel(abs_db, pipeline_db, "Legacy: пакет 1 раз/сутки", "Интеграция по БД") #Red

SHOW_LEGEND()
@enduml
