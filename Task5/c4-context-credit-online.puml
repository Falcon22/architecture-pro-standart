@startuml
!include <C4/C4_Context>

title C4 Context - Подача заявки на кредит онлайн\nSystem Context diagram [Банк "Стандарт"]

Person(client, "Клиент", "Новый или существующий. Подаёт заявку на кредит через сайт или ИБ.")
Person(fo_manager, "Менеджер фронт-офиса", "Продолжает работу с заявкой в отделении")
Person(bo_manager, "Менеджер бэк-офиса (кредиты)", "Обрабатывает заявки в Кред. конвейере")

System(site, "Сайт банка", "Кредитные предложения, заявка + мгновенный скоринг.")
System(ib, "Интернет-банк", "Кредиты, предодобренные предложения, заявка с СМС.")
System(credit_api, "Credit API Service", "Приём заявок, кэш предложений, предодобренные предложения, мгновенный скоринг, СМС.") <<new>>
System(kafka, "Apache Kafka", "credit-applications, credit-statuses")
System(pipeline, "Кредитный конвейер", "Camunda BPM. Обработка заявок, условия кредитов. + Kafka Consumer")
System(scoring, "Система скоринга", "Python / Flask / REST API. ML-модель скоринга.")
System(abs, "АБС", "Учёт операций, счета. Синхронизация заявок для фронт-офиса.")
System(batch, "Pre-scoring Batch Job", "Ночной предрасчёт скорингов") <<new>>
System_Ext(bki, "Бюро кредитных историй", "REST API")
System_Ext(sms, "СМС-шлюз", "")

Rel(client, site, "Заявка на кредит, мгновенное решение", "HTTPS")
Rel(client, ib, "Предодобренные предложения, заявка с СМС", "HTTPS")
Rel(site, credit_api, "Условия, заявки, мгновенный скоринг", "REST API")
Rel(ib, credit_api, "Предложения, предодобренные, заявки, СМС-код", "REST API")
BiRel(credit_api, kafka, "Заявки (produce), статусы (consume)", "Kafka")
Rel(credit_api, scoring, "Мгновенный скоринг (заявки с сайта)", "REST API")
Rel(credit_api, sms, "OTP, уведомления о статусе", "API")
BiRel_D(kafka, pipeline, "Прямой канал (минуя АБС!)\nЗаявки (consume), статусы (produce)", "Kafka") #Orange
Rel(kafka, abs, "Копия заявок для фронт-офиса", "Kafka Consumer")
Rel(scoring, bki, "Кредитные истории", "REST API, онлайн")
Rel(pipeline, scoring, "Скоринг заявки", "REST API")
Rel_L(batch, scoring, "Ночной предрасчёт скорингов", "REST API")
Rel_R(batch, credit_api, "Сохранение предодобренных предложений", "API")
Rel(fo_manager, abs, "Сквозная заявка, идентификация", "Десктоп")
Rel(bo_manager, pipeline, "Обработка заявок", "Веб-интерфейс")
Rel(abs, pipeline, "Legacy: пакетный обмен 1 раз/сутки (заявки из отделений)", "Интеграция по БД") #Red

SHOW_LEGEND()
@enduml
