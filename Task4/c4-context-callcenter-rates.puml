@startuml
!include <C4/C4_Context>

title C4 Context - Передача ставок депозитов в кол-центры\nSystem Context diagram [Банк "Стандарт"]

Person(client, "Клиент", "Звонит в кол-центр, спрашивает о ставках")
Person(cc_operator, "Оператор кол-центра", "200 чел.")
Person(pcc_operator, "Оператор партнёрского КЦ", "100 чел.")
Person(bo_manager, "Менеджер бэк-офиса", "Обновляет ставки")

System(cc, "Система кол-центра", "Раздел «Депозитные ставки», Kafka Consumer для ставок.")
System_Ext(pcc, "Система партнёрского кол-центра", "Получает файлы с SFTP.")
System(sftp, "SFTP-сервер", "Файлы с актуальными ставками депозитов.")
System(exporter, "Rates File Exporter", "Kafka -> CSV -> SFTP.")
System(deposit_api, "Deposit API Service", "Кэш ставок, REST API. (из Task 3)")
System(kafka, "Apache Kafka", "Топик: deposit-rates")
System(abs, "АБС", "Модуль ставок, Kafka-адаптер. Единственный источник ставок.")

Rel(client, cc_operator, "Звонит", "Телефон")
Rel(client, pcc_operator, "Звонит", "Телефон")
Rel(cc_operator, cc, "Смотрит ставки", "Веб-интерфейс")
Rel(pcc_operator, pcc, "Смотрит ставки", "Своя система")
Rel(pcc, sftp, "Забирает файлы", "SFTP")
Rel(exporter, sftp, "Выкладывает CSV", "SFTP")
Rel(exporter, kafka, "Ставки", "Kafka Consumer")
BiRel(deposit_api, kafka, "Ставки, заявки", "Kafka")
Rel(cc, kafka, "Ставки", "Kafka Consumer")
Rel(abs, kafka, "Публикует ставки", "Kafka Producer")
Rel(bo_manager, abs, "Обновляет ставки", "Десктоп")

SHOW_LEGEND()
@enduml
