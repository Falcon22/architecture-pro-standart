@startuml
!include <C4/C4_Container>

title C4 Containers - Открытие депозитов (MVP)\nContainer diagram [Банк "Стандарт"]

Person(client, "Клиент", "")
Person(fo_manager, "Менеджер фронт-офиса", "")
Person(bo_manager, "Менеджер бэк-офиса", "")
Person(cc_operator, "Оператор кол-центра", "")

System_Boundary(site_boundary, "Сайт банка") {
    Container(site_web, "Web Application", "PHP / React.js", "Страницы депозитов, форма заявки")
    ContainerDb(site_db, "БД сайта", "MySQL", "Контент")
}

System_Boundary(ib_boundary, "Интернет-банк") {
    Container(ib_monolith, "Монолит ИБ", "ASP.NET MVC 4.5", "Существующий функционал: платежи, текущие счета. Новые UI-страницы депозитов.")
    Container(ib_ui_deposit, "Deposit UI Module", "ASP.NET MVC", "Новые страницы: список депозитов, форма заявки, подтверждение СМС-кодом. Вызывает Deposit API.") <<new>>
    ContainerDb(ib_db, "БД ИБ", "MS SQL", "Данные ИБ")
}

System_Boundary(deposit_boundary, "Deposit API Service [НОВАЯ]") {
    Container(deposit_api, "Deposit API", "Java / Spring Boot", "REST API для сайта и ИБ. Приём заявок, отдача ставок, персональных предложений.") <<new>>
    Container(deposit_sms, "SMS / OTP Service", "Java / Spring Boot", "Генерация и верификация OTP-кодов, отправка уведомлений через шлюз.") <<new>>
    Container(deposit_kafka_consumer, "Kafka Consumer", "Java / Spring Boot", "Получает обновления ставок и статусов из АБС. Триггерит СМС-уведомления.") <<new>>
    ContainerDb(deposit_db, "Deposit DB", "PostgreSQL", "Заявки, кэш ставок, OTP-коды, статусы") <<new>>
}

Container(kafka, "Apache Kafka", "Кластер 3+ брокера", "Topics: deposit-applications, deposit-rates, deposit-statuses, website-applications") <<new>>

System_Boundary(abs_boundary, "АБС") {
    Container(abs_desktop, "Десктоп-клиент", "Delphi", "Интерфейс для менеджеров фронт- и бэк-офиса. Работа с заявками, счетами.")
    Container(abs_rates_module, "Модуль ставок", "PL/SQL", "Расчёт и хранение ставок депозитов. Заменяет Excel. Ролевой доступ для бэк-офиса деп./кред.") <<new>>
    Container(abs_kafka_adapter, "Kafka-адаптер АБС", "Java", "Мост: Kafka <-> Oracle. Читает заявки из Kafka, публикует ставки/статусы.") <<new>>
    ContainerDb(abs_db, "Oracle DB", "Oracle PL/SQL", "Основная БД: счета, клиенты, операции, ставки")
}

System_Boundary(cc_boundary, "Система кол-центра") {
    Container(cc_web, "КЦ Web App", "React.js / Java Spring Boot", "Приём обращений")
    Container(cc_kafka_consumer, "Kafka Consumer", "Java", "Получает заявки с сайта") <<new>>
}

System_Ext(sms_gateway, "СМС-шлюз", "Телеком-оператор")

Rel(client, site_web, "Смотрит депозиты, подаёт заявку", "HTTPS")
Rel(client, ib_ui_deposit, "Депозиты, заявки, СМС-подтверждение", "HTTPS")
Rel(site_web, deposit_api, "Ставки, заявки", "REST API / HTTPS")
Rel(ib_ui_deposit, deposit_api, "Ставки, персональные предложения, заявки", "REST API / HTTPS")
Rel(ib_ui_deposit, deposit_sms, "Запрос / проверка OTP-кода", "REST API / HTTPS")
Rel(ib_monolith, ib_db, "", "SQL")
Rel(deposit_api, deposit_db, "", "SQL/JDBC")
Rel(deposit_db, kafka, "Публикует заявки", "Kafka Producer")
Rel(kafka, deposit_kafka_consumer, "Ставки, статусы из АБС", "Kafka Consumer")
Rel(deposit_sms, sms_gateway, "OTP + уведомления", "API")
BiRel(kafka, abs_kafka_adapter, "Заявки (consume), ставки/статусы (produce)", "Kafka")
BiRel(abs_kafka_adapter, abs_db, "", "JDBC / PL/SQL")
Rel(abs_desktop, abs_db, "", "Oracle Client")
Rel(abs_rates_module, abs_db, "", "PL/SQL")
Rel(kafka, cc_kafka_consumer, "Заявки с сайта", "Kafka Consumer")
Rel(cc_kafka_consumer, cc_web, "Создаёт обращение", "Internal API")
Rel(fo_manager, abs_desktop, "Оформляет депозиты", "Десктоп")
Rel(bo_manager, abs_desktop, "Обрабатывает заявки, подтверждает ставки", "Десктоп")
Rel(bo_manager, abs_rates_module, "Управляет ставками", "")
Rel(cc_operator, cc_web, "Обрабатывает заявки", "Веб")

Rel(ib_monolith, abs_db, "Существующая прямая интеграция по БД (платежи, текущие счета)", "ODBC -> Oracle") #Red

SHOW_LEGEND()
@enduml
