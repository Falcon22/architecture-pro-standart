@startuml
!include <C4/C4_Context>

title C4 Context - Открытие депозитов (MVP)\nSystem Context diagram [Банк "Стандарт"]

Person(client, "Клиент", "Новый или существующий клиент банка. Подаёт заявки на депозиты через сайт или ИБ.")
Person(fo_manager, "Менеджер фронт-офиса", "Работает в отделении, оформляет депозиты в АБС.")
Person(bo_manager, "Менеджер бэк-офиса", "Обрабатывает заявки на депозиты в АБС. Подтверждает ставку.")
Person(cc_operator, "Оператор кол-центра", "Обрабатывает заявки с сайта, связывается с клиентом.")

System(site, "Сайт банка", "Отображает депозиты со ставками, принимает заявки от новых клиентов.")
System(ib, "Интернет-банк", "Отображает депозиты с персональными ставками, подача заявок с СМС.")
System(deposit_api, "Deposit API Service", "Микросервис: приём заявок, кэш ставок, СМС-подтверждение, асинхронная интеграция с АБС.") <<new>>
System(abs, "АБС", "Учёт операций, счета, модуль ставок, обработка заявок.")
System(cc, "Система кол-центра", "Приём обращений, работа с заявками от клиентов с сайта.")
System(kafka, "Apache Kafka", "Брокер сообщений. Асинхронная интеграция.") <<new>>
System_Ext(sms, "СМС-шлюз", "Отправка СМС через телеком-оператора.")

Rel(client, site, "Смотрит депозиты, подаёт заявку", "HTTPS")
Rel(client, ib, "Смотрит депозиты, подаёт заявку с СМС", "HTTPS")
Rel(site, deposit_api, "Ставки, заявки", "REST API / HTTPS")
Rel(ib, deposit_api, "Ставки, персональные предложения, заявки, СМС-подтверждение", "REST API / HTTPS")
BiRel(deposit_api, kafka, "Заявки, ставки, статусы", "Async / Kafka")
BiRel(kafka, abs, "Заявки, обновления ставок, статусы", "Async / Kafka")
Rel(kafka, cc, "Заявки с сайта", "Async / Kafka")
Rel(deposit_api, sms, "OTP-коды, уведомления", "API")
Rel(fo_manager, abs, "Оформляет депозиты", "Десктоп-клиент")
Rel(bo_manager, abs, "Обрабатывает заявки, подтверждает ставки", "Десктоп-клиент")
Rel(cc_operator, cc, "Обрабатывает заявки с сайта", "Веб-интерфейс")

SHOW_LEGEND()
@enduml
